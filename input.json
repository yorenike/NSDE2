{
    "dimension": 1,
    
    "problem": {
        "type": "poisson",
        "domain": {
            "xmin": 0.0,
            "xmax": 1.0,
            "ymin": 0.0,
            "ymax": 1.0
        }
    },
    
    "grid": {
        "n": 256
    },
    
    "boundary": {
        "left": {
            "type": "neumann",
            "value": "from_test_function"
        },
        "right": {
            "type": "dirichlet",
            "value": "from_test_function"
        },
        "bottom": {
            "type": "dirichlet",
            "value": "from_test_function"
        },
        "top": {
            "type": "dirichlet",
            "value": "from_test_function"
        }
    },
    
    "test_function": {
        "name": "exp_y_sin_x"
    },
    
    "multigrid": {
        "restriction": "full_weighting",
        "interpolation": "linear",
        "cycle": "V",
        "nu1": 2,
        "nu2": 2,
        "epsilon": 1e-8,
        "max_iter": 500
    },
    
    "output": {
        "verbose": true,
        "save_solution": false,
        "output_dir": "./results"
    }
}